{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": ["eslint", "typescript"],
	"ignorePatterns": ["node_modules/**", "**/dist/**", "coverage/**", "vendor/**", "test/snapshots/**"],
    "env": {
        "browser": true
    },
    "categories": {
        "correctness": "error"
    }
}
