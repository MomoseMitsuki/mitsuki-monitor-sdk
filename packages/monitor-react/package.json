{
  "name": "@mitsuki-monitor-sdk/react",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MomoseMitsuki/mitsuki-monitor-sdk.git"
  },
  "description": "The wrapper layer of mitsuki-monitor-sdk on react.",
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.mjs",
    "require": "./dist/index.cjs"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "buildOptions": {
    "name": "MonitorReact",
    "formats": [
      "esm",
      "cjs",
	  "iife"
    ],
	"external": ["react", "react-router-dom", "@mitsuki-monitor-sdk/core"],
	"globals": {
	  "react": "React",
	  "react-router-dom": "ReactRouterDOM",
	  "@mitsuki-monitor-sdk/core": "MonitorSdkCore"
	}
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["monitor", "react", "react-router"],
  "author": "momosemitsuki",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
	"@types/react": "^19.2.14"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-router-dom": "^7.0.0",
	"@mitsuki-monitor-sdk/core": "workspace:^"
  }
}
