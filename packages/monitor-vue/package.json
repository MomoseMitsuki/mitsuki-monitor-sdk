{
  "name": "@mitsuki-monitor-sdk/vue",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MomoseMitsuki/mitsuki-monitor-sdk.git"
  },
  "description": "The wrapper layer of mitsuki-monitor-sdk on vue.",
  "type": "module",
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.mjs",
    "require": "./dist/index.cjs"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "buildOptions": {
    "name": "MonitorVue",
    "formats": [
      "esm",
      "cjs",
	  "iife"
    ],
	"external": ["vue", "vue-router", "@mitsuki-monitor-sdk/core"],
	"globals": {
	  "@mitsuki-monitor-sdk/core": "MonitorSdkCore"
	}
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["monitor", "vue", "vue-router"],
  "author": "momosemitsuki",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "peerDependencies": {
    "vue": "^3.0.0",
    "vue-router": "^5.0.0",
	"@mitsuki-monitor-sdk/core": "workspace:*"
  }
}
