{
  "name": "mitsuki-monitor-sdk",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MomoseMitsuki/mitsuki-monitor-sdk.git"
  },
  "description": "mitsuki-monitor-sdk is used for error monitoring, performance analysis, event tracking data collection, interface collection...",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "build": "node ./scripts/build.mjs",
	"example:vue": "pnpm --filter @monitor-example/vue dev",
	"example:react": "pnpm --filter @monitor-example/react dev",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "lint:prettier": "prettier --write \"**/*.{js,ts,mjs,cjs,json,tsx,css,less,scss,vue,html,md}\"",
    "lint:spellcheck": "cspell lint \"**/*.{js,ts,mjs,cjs,json,css,less,scss,vue,html.md}\"",
    "publish": "run-s publish:*",
    "publish:core": "pnpm --filter @mitsuki-monitor-sdk/core publish",
    "publish:vue": "pnpm --filter @mitsuki-monitor-sdk/vue publish",
    "publish:react": "pnpm --filter @mitsuki-monitor-sdk/react publish",
    "commit": "git-cz",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "keywords": ["monitor"],
  "author": "momosemitsuki",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@cspell/dict-lorem-ipsum": "^4.0.5",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "commitizen": "^4.3.1",
    "cspell": "^10.0.0",
    "cz-git": "^1.12.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.59.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.59.0",
    "prettier": "^3.8.2",
    "rollup": "^4.60.1",
    "rollup-plugin-delete": "^3.0.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
